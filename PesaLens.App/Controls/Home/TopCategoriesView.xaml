<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:PesaLens.App.Converters"
    xmlns:vm="clr-namespace:PesaLens.App.ViewModels"
    x:Class="PesaLens.App.Controls.Home.TopCategoriesView"
    x:Name="this">

    <ContentView.Resources>
        <converters:IntIsZeroConverter    x:Key="IntIsZero"/>
        <converters:IntIsNonZeroConverter x:Key="IntIsNonZero"/>
        <converters:IconNameToGlyphConverter x:Key="IconNameToGlyph"/>
    </ContentView.Resources>

    <VerticalStackLayout Spacing="10">

        <Label
            Text="Top categories"
            FontSize="16"
            FontAttributes="Bold"
            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

        <ScrollView
            Orientation="Horizontal"
            HorizontalScrollBarVisibility="Never"
            IsVisible="{Binding Source={x:Reference this}, Path=Categories.Count, Converter={StaticResource IntIsNonZero}}">
            <HorizontalStackLayout
                Spacing="10"
                BindableLayout.ItemsSource="{Binding Source={x:Reference this}, Path=Categories}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategorySpendItem">
                        <Border
                            WidthRequest="148"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                            <VerticalStackLayout Spacing="8">

                                <Border
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource PrimaryContainerDark}}">
                                    <Image HorizontalOptions="Center" VerticalOptions="Center"
                                        WidthRequest="20" HeightRequest="20">
                                        <Image.Source>
                                            <FontImageSource
                                                FontFamily="MaterialSharp"
                                                Glyph="{Binding Icon, Converter={StaticResource IconNameToGlyph}}"
                                                Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                                Size="20"/>
                                        </Image.Source>
                                    </Image>
                                </Border>

                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="{Binding Name}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                        LineBreakMode="TailTruncation"/>
                                    <Label
                                        Text="{Binding FormattedAmount}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <Label
            Text="No spending data yet for this period."
            FontSize="14"
            HorizontalTextAlignment="Center"
            HorizontalOptions="Center"
            IsVisible="{Binding Source={x:Reference this}, Path=Categories.Count, Converter={StaticResource IntIsZero}}"
            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>

    </VerticalStackLayout>
</ContentView>