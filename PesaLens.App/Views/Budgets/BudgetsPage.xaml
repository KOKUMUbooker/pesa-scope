<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage
    x:Class="PesaLens.App.Views.Budgets.BudgetsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:vm="clr-namespace:PesaLens.App.ViewModels"
    xmlns:converters="clr-namespace:PesaLens.App.Converters"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    x:DataType="vm:BudgetsViewModel"
    x:Name="NBudgetsPage"
    SafeAreaEdges="All"
    BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <uranium:UraniumContentPage.Resources>
        <converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
        <converters:InverseBoolConverter x:Key="InvertedBool"/>
        <converters:IntIsZeroConverter x:Key="IntIsZero"/>
    </uranium:UraniumContentPage.Resources>

    <!-- ── Title bar ─────────────────────────────────────────────────────── -->
    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="5,10" >
            <Label Grid.Column="0" Text="Budgets" FontSize="22" FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
            <ImageButton Grid.Column="1" Command="{Binding OpenOverallBudgetCommand}"
                         BackgroundColor="Transparent" Padding="8" WidthRequest="44" HeightRequest="44"
                         ToolTipProperties.Text="Set overall budget">
                <ImageButton.Source>
                    <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Tune}"
                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Size="20"/>
                </ImageButton.Source>
            </ImageButton>
        </Grid>
    </Shell.TitleView>

    <!-- ── Bottom sheets ─────────────────────────────────────────────────── -->
    <uranium:UraniumContentPage.Attachments>

        <!-- Category budget sheet -->
        <material:BottomSheetView
            x:Name="BudgetSheet"
            IsPresented="{Binding IsSheetOpen}"
            IsVisible="{Binding IsSheetOpen}"
            CloseOnTapOutside="False"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

            <VerticalStackLayout Padding="24,12,24,48" Spacing="20">

                <Label FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0} Budget">
                            <Binding Path="EditingRow.Category.Name"/>
                        </MultiBinding>
                    </Label.Text>
                </Label>

                <!-- Monthly limit -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="MONTHLY LIMIT (KSH)" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,0">
                        <Entry Text="{Binding EditLimitText}"
                               Keyboard="Numeric"
                               Placeholder="e.g. 5000"
                               FontSize="16" HeightRequest="52"
                               BackgroundColor="Transparent"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Warning threshold -->
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="WARNING THRESHOLD" FontSize="11"
                               FontAttributes="Bold" CharacterSpacing="1.2"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        <Label Grid.Column="1" FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDark}}">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}%">
                                    <Binding Path="EditWarningThreshold"/>
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </Grid>
                    <Slider Minimum="50" Maximum="95" Value="{Binding EditWarningThreshold}"
                            MinimumTrackColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            MaximumTrackColor="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            ThumbColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                </VerticalStackLayout>

                <!-- Notifications toggle -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Notifications" FontSize="15"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                        <Label Text="Alert me when I approach this limit"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding EditNotificationsEnabled}"
                            OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            VerticalOptions="Center"/>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" Text="Cancel" Command="{Binding CloseSheetCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    <Button Grid.Column="1" Text="Save" Command="{Binding SaveBudgetCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"/>
                </Grid>
            </VerticalStackLayout>
        </material:BottomSheetView>

        <!-- Overall budget sheet -->
        <material:BottomSheetView
            x:Name="OverallSheet"
            IsPresented="{Binding IsOverallSheetOpen}"
            IsVisible="{Binding IsOverallSheetOpen}"
            CloseOnTapOutside="False"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

            <VerticalStackLayout Padding="24,12,24,48" Spacing="20">
                <Label Text="Overall Monthly Budget" FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                <Label Text="Set a total spending limit across all categories for the month."
                       FontSize="13" HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>

                <VerticalStackLayout Spacing="6">
                    <Label Text="MONTHLY LIMIT (KSH)" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,0">
                        <Entry Text="{Binding EditOverallLimitText}"
                               Keyboard="Numeric"
                               Placeholder="e.g. 30000"
                               FontSize="16" HeightRequest="52"
                               BackgroundColor="Transparent"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" Text="Cancel" Command="{Binding CloseSheetCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    <Button Grid.Column="1" Text="Save" Command="{Binding SaveOverallBudgetCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"/>
                </Grid>
            </VerticalStackLayout>
        </material:BottomSheetView>

    </uranium:UraniumContentPage.Attachments>

    <!-- ── Main content ───────────────────────────────────────────────────── -->
    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="20,16,20,40">

            <!-- ── Overall budget card (5.5) ────────────────────────────── -->
            <Border
    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
    StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="20">

                <Grid>
                    <!-- Loading indicator for overall budget -->
                    <Grid IsVisible="{Binding IsOverallBudgetLoading}">
                        <VerticalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center" Padding="20,30">
                            <ActivityIndicator IsRunning="{Binding IsOverallBudgetLoading}" 
                                 Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                 WidthRequest="36" HeightRequest="36"/>
                            <Label Text="Loading overall budget..."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Content -->
                    <VerticalStackLayout Spacing="12" IsVisible="{Binding IsOverallBudgetLoading, Converter={StaticResource InvertedBool}}">

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Overall budget"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                <Label Text="{Binding PeriodLabel}" FontSize="12"
                                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource PrimaryContainerDark}}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 20"
                                Padding="14,8" VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenOverallBudgetCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="{Binding HasOverallBudget, Converter={StaticResource BoolToStringConverter},
                           ConverterParameter='Edit|Set budget'}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                            </Border>
                        </Grid>

                        <!-- Spent vs limit numbers -->
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding FormattedOverallSpent}"
                           FontSize="28" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                <Label FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="of {0} budget">
                                            <Binding Path="FormattedOverallLimit"/>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>
                            <Label Grid.Column="1"
                       Text="{Binding OverallStatusLabel}"
                       FontSize="13" FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{Binding OverallProgressColor}"/>
                        </Grid>

                        <!-- Progress bar -->
                        <ProgressBar Progress="{Binding OverallProgress}"
                         ProgressColor="{Binding OverallProgressColor}"
                         BackgroundColor="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                         HeightRequest="8"/>

                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- ── Category budgets (5.1, 5.2, 5.7) ─────────────────────── -->
            <VerticalStackLayout Spacing="10">

                <Label Text="Category budgets" FontSize="16" FontAttributes="Bold"
           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                <!-- Loading indicator for category budgets -->
                <Border IsVisible="{Binding IsCategoryBudgetsLoading}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="40,30">
                    <VerticalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="{Binding IsCategoryBudgetsLoading}" 
                             Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                             WidthRequest="36" HeightRequest="36"/>
                        <Label Text="Loading category budgets..."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Content -->
                <VerticalStackLayout IsVisible="{Binding IsCategoryBudgetsLoading, Converter={StaticResource InvertedBool}}"
                         BindableLayout.ItemsSource="{Binding BudgetRows}" Spacing="12">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:BudgetRow">
                            <Border
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                                StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16">
                                <VerticalStackLayout Spacing="10">

                                    <!-- Category header row -->
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">

                                        <Label Grid.Column="0"
                                           Text="{Binding Category.Name}"
                                           FontSize="15" FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                                        <!-- Delete budget button (only if budget exists) -->
                                        <ImageButton Grid.Column="1"
                                            BackgroundColor="Transparent"
                                            WidthRequest="36" HeightRequest="36"
                                            IsVisible="{Binding HasBudget}"
                                            Command="{Binding BindingContext.DeleteBudgetCommand, Source={x:Reference NBudgetsPage}}"
                                            CommandParameter="{Binding .}">
                                            <ImageButton.Source>
                                                <FontImageSource FontFamily="MaterialSharp"
                                                    Glyph="{x:Static m:MaterialSharp.Delete}"
                                                    Color="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                                                    Size="16"/>     
                                            </ImageButton.Source>
                                        </ImageButton>

                                        <!-- Set / Edit budget button -->
                                        <Border Grid.Column="2"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 16"
                                                Padding="12,6" VerticalOptions="Center"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource PrimaryContainerDark}}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding BindingContext.OpenEditBudgetCommand, Source={x:Reference NBudgetsPage}}"
                                                    CommandParameter="{Binding .}"/>    
                                            </Border.GestureRecognizers>
                                            <Label FontSize="12" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       Text="{Binding HasBudget, Converter={StaticResource BoolToStringConverter},
                                              ConverterParameter='Edit|Set limit'}"/>
                                        </Border>
                                    </Grid>

                                    <!-- Progress section — only shown when budget is set -->
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding HasBudget}">

                                        <!-- Spent / limit -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" FontSize="13"
                                       Text="{Binding Category.Name, StringFormat='{0} Budget'}"
                                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}">
                                            </Label>
                                            <Label Grid.Column="1" FontSize="13"
                                       Text="{Binding FormattedLimit, StringFormat='of {0}'}" 
                                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}">
                                            </Label>
                                        </Grid>

                                        <!-- Progress bar (5.2) -->
                                        <ProgressBar Progress="{Binding Progress}"
                                         ProgressColor="{Binding ProgressColor}"
                                         BackgroundColor="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                                         HeightRequest="8"/>

                                        <!-- Status + last month comparison (5.7) -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0"
                                       Text="{Binding StatusLabel}"
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="{Binding ProgressColor}"/>
                                            <Label Grid.Column="1"
                                       Text="{Binding LastMonthLabel}"
                                       FontSize="11"
                                       TextColor="{Binding LastMonthColor}"/>
                                        </Grid>

                                    </VerticalStackLayout>

                                    <!-- No budget set state -->
                                    <Label Text="No limit set — tap 'Set limit' to add one."
                               FontSize="12"
                               IsVisible="{Binding HasBudget, Converter={StaticResource InvertedBool}}"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</uranium:UraniumContentPage>