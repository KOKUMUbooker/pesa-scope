<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage
    x:Class="PesaLens.App.Views.Categories.CategoriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
    xmlns:vm="clr-namespace:PesaLens.App.ViewModels"
    xmlns:models="clr-namespace:PesaLens.Core.Models;assembly=PesaLens.Core"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    xmlns:converters="clr-namespace:PesaLens.App.Converters"
    x:DataType="vm:CategoriesViewModel"
    SafeAreaEdges="All"
    BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <!-- ── Title bar ─────────────────────────────────────────────────────── -->
    <Shell.TitleView  BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
        <Grid ColumnDefinitions="*,Auto,Auto" Padding="5,10" >
            <Label Grid.Column="0" Text="Categories" FontSize="22" FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
            <ImageButton Grid.Column="1" Command="{Binding OpenAddRuleCommand}"
                         BackgroundColor="Transparent" Padding="8" WidthRequest="44" HeightRequest="44">
                <ImageButton.Source>
                    <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Rule}"
                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Size="20"/>
                </ImageButton.Source>
            </ImageButton>

            <ImageButton Grid.Column="2" Command="{Binding OpenAddCategoryCommand}"
                         BackgroundColor="Transparent" Padding="8" WidthRequest="44" HeightRequest="44">
                <ImageButton.Source>
                    <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Add}"
                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Size="20"/>
                </ImageButton.Source>
            </ImageButton>
        </Grid>
    </Shell.TitleView>

    <uranium:UraniumContentPage.Attachments>

        <!-- ── Add / Edit Category sheet ─────────────────────────────────── -->
        <material:BottomSheetView
            x:Name="CategorySheet"
            IsPresented="{Binding IsSheetOpen}"
            IsVisible="{Binding IsSheetOpen}"
            CloseOnTapOutside="False"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

            <VerticalStackLayout Padding="24,12,24,48" Spacing="16">
                <Label Text="{Binding EditingCategory, Converter={StaticResource NullToStringConverter},
                       ConverterParameter='Edit Category|New Category'}"
                       FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                <VerticalStackLayout Spacing="6">
                    <Label Text="NAME" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,0">
                        <Entry Text="{Binding EditName}" Placeholder="e.g. Subscriptions"
                               FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="COLOR" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="10" x:Name="ColorPickerLayout"/>
                    </ScrollView>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" Text="Cancel" Command="{Binding CloseSheetCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    <Button Grid.Column="1" Text="Save" Command="{Binding SaveCategoryCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"/>
                </Grid>
            </VerticalStackLayout>
        </material:BottomSheetView>

        <!-- ── Add / Edit Rule sheet ──────────────────────────────────────── -->
        <material:BottomSheetView
            x:Name="RuleSheet"
            IsPresented="{Binding IsRuleSheetOpen}"
            IsVisible="{Binding IsRuleSheetOpen}"
            CloseOnTapOutside="False"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

            <VerticalStackLayout Padding="24,12,24,48" Spacing="16">
                <Label Text="Auto-Categorization Rule" FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                <VerticalStackLayout Spacing="6">
                    <Label Text="RULE TYPE" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Picker ItemsSource="{Binding RuleTypes}"
                                SelectedItem="{Binding RuleType}"
                                FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="MATCH VALUE" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,0">
                        <Entry Text="{Binding RuleMatchValue}" Placeholder="e.g. NAIVAS or 888880"
                               FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="ASSIGN TO CATEGORY" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,4"
                            x:Name="CategoryPickerBorder">
                        <Picker x:Name="RuleCategoryPicker"
                                ItemDisplayBinding="{Binding Name}"
                                FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                                SelectedIndexChanged="OnRuleCategorySelected"/>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" Text="Cancel" Command="{Binding CloseSheetCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    <Button Grid.Column="1" Text="Save" Command="{Binding SaveRuleCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"/>
                </Grid>
            </VerticalStackLayout>
        </material:BottomSheetView>

    </uranium:UraniumContentPage.Attachments>

    <!-- ── Main content ───────────────────────────────────────────────────── -->
    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="20,16,20,40">

            <!-- ── Donut chart ───────────────────────────────────────────── -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16">
                <Grid>
                    <!-- Chart content -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Spending breakdown"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                        <Label Text="{Binding PeriodLabel}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        <lvc:PieChart
                            HeightRequest="220"
                            Background="Transparent"
                            Series="{Binding Series}"
                            LegendPosition="Hidden"
                            TooltipPosition="Top"
                            TooltipBackgroundPaint="{x:Null}"
                            TooltipTextPaint="{x:Null}"
                            AnimationsSpeed="00:00:00.500" />
                    </VerticalStackLayout>

                    <!-- Activity indicator overlay -->
                    <ActivityIndicator
                        IsRunning="{Binding IsChartLoading}"
                        IsVisible="{Binding IsChartLoading}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        WidthRequest="40"
                        HeightRequest="40"/>
                </Grid>
            </Border>

            <!-- ── Category rows (4.3) ───────────────────────────────────── -->
            <VerticalStackLayout Spacing="10">
                <Label Text="All categories" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="0">
                    <Grid>
                        <!-- Categories list -->
                        <VerticalStackLayout
                            BindableLayout.ItemsSource="{Binding CategoryRows}"
                            Spacing="0"
                            IsVisible="{Binding IsChartLoading, Converter={StaticResource InvertedBoolConverter}}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategorySpendRow">
                                    <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=SelectCategoryCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Grid.GestureRecognizers>

                                        <!-- Color dot -->
                                        <BoxView Grid.Column="0"
                                                 WidthRequest="12" HeightRequest="12"
                                                 CornerRadius="6"
                                                 Color="{Binding ChartColor}"
                                                 VerticalOptions="Center"/>

                                        <!-- Name -->
                                        <Label Grid.Column="1"
                                               Text="{Binding Category.Name}"
                                               FontSize="15"
                                               VerticalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                                        <!-- Percentage -->
                                        <Label Grid.Column="2"
                                               Text="{Binding FormattedPercentage}"
                                               FontSize="13"
                                               VerticalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>

                                        <!-- Amount + edit button -->
                                        <HorizontalStackLayout Grid.Column="3" Spacing="8" VerticalOptions="Center">
                                            <Label Text="{Binding FormattedAmount}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                                            <ImageButton
                                                BackgroundColor="Transparent"
                                                WidthRequest="32" HeightRequest="32"
                                                IsVisible="{Binding Category.IsSystemCategory, Converter={StaticResource InvertedBoolConverter}}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=OpenEditCategoryCommand}"
                                                CommandParameter="{Binding .}">

                                                <ImageButton.Source>
                                                    <FontImageSource FontFamily="MaterialSharp"
                                                        Glyph="{x:Static m:MaterialSharp.Edit}"
                                                        Color="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                                        Size="16"/>
                                                </ImageButton.Source>
                                            </ImageButton>
                                        </HorizontalStackLayout>

                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Activity indicator -->
                        <ActivityIndicator
                            IsRunning="{Binding IsChartLoading}"
                            IsVisible="{Binding IsChartLoading}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            WidthRequest="40"
                            HeightRequest="40"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- ── Auto-categorization rules (4.6) ──────────────────────── -->
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Auto-categorization rules"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    <Label Grid.Column="1" Text="+ Add rule"
                           FontSize="13" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenAddRuleCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="0">

                    <Grid>
                        <!-- Rules list -->
                        <VerticalStackLayout 
                            BindableLayout.ItemsSource="{Binding Rules}" 
                            Spacing="0"
                            IsVisible="{Binding IsRulesLoading, Converter={StaticResource InvertedBoolConverter}}">

                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:AutoCategorizationRule">
                                    <Grid Padding="16,14" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding MatchValue}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                                            <Label Text="{Binding RuleType}"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                                        </VerticalStackLayout>

                                        <ImageButton Grid.Column="1"
                                            BackgroundColor="Transparent"
                                            WidthRequest="36" HeightRequest="36"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=OpenEditRuleCommand}"
                                            CommandParameter="{Binding .}">

                                            <ImageButton.Source>
                                                <FontImageSource FontFamily="MaterialSharp"
                                                    Glyph="{x:Static m:MaterialSharp.Edit}"
                                                    Color="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                                    Size="16"/>
                                            </ImageButton.Source>

                                        </ImageButton>

                                        <ImageButton Grid.Column="2"
                                            BackgroundColor="Transparent"
                                            WidthRequest="36" HeightRequest="36"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=DeleteRuleCommand}"
                                            CommandParameter="{Binding .}">

                                            <ImageButton.Source>
                                                <FontImageSource FontFamily="MaterialSharp"
                                                    Glyph="{x:Static m:MaterialSharp.Delete}"
                                                    Color="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                                                    Size="16"/>
                                            </ImageButton.Source>

                                        </ImageButton>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Activity indicator -->
                        <ActivityIndicator
                            IsRunning="{Binding IsRulesLoading}"
                            IsVisible="{Binding IsRulesLoading}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            WidthRequest="40"
                            HeightRequest="40"/>

                    </Grid>

                </Border>

                <Label Text="No rules yet. Tap '+ Add rule' to create one."
                       FontSize="14" HorizontalTextAlignment="Center" HorizontalOptions="Center"
                       Margin="0,4"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}">
                    <Label.IsVisible>
                        <Binding Path="Rules.Count" Converter="{StaticResource IntIsZero}"/>
                    </Label.IsVisible>
                </Label>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

    <uranium:UraniumContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        <converters:IntIsZeroConverter x:Key="IntIsZero"/>
    </uranium:UraniumContentPage.Resources>
</uranium:UraniumContentPage>