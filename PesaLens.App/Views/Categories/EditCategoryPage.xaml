<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage
    x:Class="PesaLens.App.Views.Categories.EditCategoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
    xmlns:vm="clr-namespace:PesaLens.App.ViewModels.Categories"
    xmlns:converters="clr-namespace:PesaLens.App.Converters"
    x:DataType="vm:EditCategoryViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <ContentPage.Resources>
       <!-- <converters:StringEqualsConverter      x:Key="StrEq"/>
        <converters:StringEqualsToBoolConverter x:Key="StrEqBool"/>
        <converters:HexToColorConverter        x:Key="HexToColor"/>  -->
        <converters:IntIsNonZeroConverter      x:Key="IntIsNonZero"/>
    </ContentPage.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Root scroll — lets the icon picker expand without clipping
    ════════════════════════════════════════════════════════════════════════ -->
    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ── TOP APP BAR ─────────────────────────────────────────────── -->
            <Grid
                Padding="8,52,8,8"
                ColumnDefinitions="48,*,48"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

                <!-- Back / Cancel -->
                <ImageButton
                    Grid.Column="0"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent"
                    HeightRequest="40"
                    WidthRequest="40"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <ImageButton.Source>
                        <FontImageSource
                            Glyph="&#xE5C4;"
                            FontFamily="MaterialIcons"
                            Size="24"
                            Color="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </ImageButton.Source>
                </ImageButton>

                <!-- Title -->
                <Label
                    Grid.Column="1"
                    Text="{Binding PageTitle}"
                    FontSize="18"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                <!-- Save button (top-right) -->
                <Button
                    Grid.Column="2"
                    Text="Save"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}"
                    BackgroundColor="Transparent"
                    FontSize="15"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    Padding="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>
            </Grid>

            <!-- Hairline -->
            <BoxView
                HeightRequest="1"
                Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                Opacity="0.5"/>

            <!-- ── BODY ──────────────────────────────────────────────────── -->
            <VerticalStackLayout Padding="20,24,20,40" Spacing="24">

                <!-- Busy indicator -->
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    HorizontalOptions="Center"/>

                <!-- ── PREVIEW CARD ──────────────────────────────────────── -->
                <!--
                    Live preview of the category badge the user is designing.
                    BackgroundColor is driven by SelectedColor via HexToColorConverter.
                -->
                <Border
                    HorizontalOptions="Center"
                    WidthRequest="96"
                    HeightRequest="96"
                    StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    BackgroundColor="{Binding SelectedColor, Converter={StaticResource HexToColor}}">
                    <Label
                        Text="{Binding SelectedIcon}"
                        FontSize="42"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

                <!-- ── SYSTEM CATEGORY NOTICE ────────────────────────────── -->
                <Border
                    IsVisible="{Binding IsSystemCategory}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SecondaryContainer}, Dark={StaticResource SecondaryContainerDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 10"
                    Padding="14,10">
                    <HorizontalStackLayout Spacing="8">
                        <Label
                            Text="🔒"
                            FontSize="16"
                            VerticalOptions="Center"/>
                        <Label
                            Text="This is a built-in category. You can rename it or change its icon and colour, but it cannot be deleted."
                            FontSize="13"
                            LineBreakMode="WordWrap"
                            VerticalOptions="Center"
                            TextColor="{AppThemeBinding Light={StaticResource OnSecondaryContainer}, Dark={StaticResource OnSecondaryContainerDark}}"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- ── NAME FIELD ────────────────────────────────────────── -->
                <VerticalStackLayout Spacing="6">

                    <Label
                        Text="Category name"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>

                    <Border
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="1.5"
                        Padding="0">
                        <!-- Border stroke changes to Primary when focused — handled via VisualState below -->
                        <Border.Stroke>
                            <AppThemeBinding
                                Light="{StaticResource OutlineVariant}"
                                Dark="{StaticResource OutlineVariantDark}"/>
                        </Border.Stroke>
                        <Entry
                            Text="{Binding Name}"
                            Placeholder="e.g. Groceries"
                            FontSize="16"
                            Margin="14,0"
                            PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                            BackgroundColor="Transparent"
                            HeightRequest="52"
                            ReturnType="Done"
                            ClearButtonVisibility="WhileEditing"/>
                    </Border>

                    <!-- Inline validation error -->
                    <Label
                        Text="{Binding NameError}"
                        FontSize="12"
                        TextColor="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                        IsVisible="{Binding NameError.Length, Converter={StaticResource IntIsNonZero}}"/>

                </VerticalStackLayout>

                <!-- ── ICON PICKER ────────────────────────────────────────── -->
                <VerticalStackLayout Spacing="6">

                    <Label
                        Text="Icon"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>

                    <!-- Icon selector button — shows current selection -->
                    <Border
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="1.5"
                        Padding="14,0">
                        <Border.Stroke>
                            <AppThemeBinding
                                Light="{StaticResource OutlineVariant}"
                                Dark="{StaticResource OutlineVariantDark}"/>
                        </Border.Stroke>
                        <Border.BackgroundColor>
                            <AppThemeBinding
                                Light="{StaticResource Surface}"
                                Dark="{StaticResource SurfaceDark}"/>
                        </Border.BackgroundColor>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleIconPickerCommand}"/>
                        </Border.GestureRecognizers>
                        <Grid
                            HeightRequest="52"
                            ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                FontSize="24"
                                VerticalOptions="Center"
                                Text="{Binding SelectedIcon}"/>
                            <Label
                                Grid.Column="1"
                                Text="▾"
                                FontSize="14"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                        </Grid>
                    </Border>

                    <!-- Inline icon picker panel — collapses when IsIconPickerVisible = false -->
                    <Border
                        IsVisible="{Binding IsIconPickerVisible}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">

                        <VerticalStackLayout Spacing="16">
                            <!-- Repeat per group using BindableLayout -->
                            <BindableLayout.ItemsSource>
                                <!-- We can't use BindableLayout on VerticalStackLayout directly
                                     for grouped data, so we use a CollectionView inside -->
                            </BindableLayout.ItemsSource>

                            <CollectionView
                                ItemsSource="{Binding IconGroups}"
                                SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:IconGroup">
                                        <VerticalStackLayout Spacing="8" Padding="0,0,0,8">

                                            <!-- Group label -->
                                            <Label
                                                Text="{Binding Label}"
                                                FontSize="11"
                                                FontAttributes="Bold"
                                                CharacterSpacing="1"
                                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>

                                            <!-- Icon grid — 10 per row via wrapping HorizontalStackLayout -->
                                            <FlexLayout
                                                Wrap="Wrap"
                                                JustifyContent="Start"
                                                AlignItems="Center"
                                                BindableLayout.ItemsSource="{Binding Icons}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="{x:Type x:String}">
                                                        <Border
                                                            WidthRequest="44"
                                                            HeightRequest="44"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0"
                                                            Margin="2"
                                                            BackgroundColor="Transparent">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditCategoryViewModel}}, Path=SelectIconCommand}"
                                                                    CommandParameter="{Binding .}"/>
                                                            </Border.GestureRecognizers>
                                                            <Label
                                                                Text="{Binding .}"
                                                                FontSize="24"
                                                                HorizontalOptions="Center"
                                                                VerticalOptions="Center"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </FlexLayout>

                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

                <!-- ── COLOR PICKER ───────────────────────────────────────── -->
                <VerticalStackLayout Spacing="6">

                    <Label
                        Text="Colour"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>

                    <!-- Color selector button — shows current swatch -->
                    <Border
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="1.5"
                        Padding="14,0">
                        <Border.Stroke>
                            <AppThemeBinding
                                Light="{StaticResource OutlineVariant}"
                                Dark="{StaticResource OutlineVariantDark}"/>
                        </Border.Stroke>
                        <Border.BackgroundColor>
                            <AppThemeBinding
                                Light="{StaticResource Surface}"
                                Dark="{StaticResource SurfaceDark}"/>
                        </Border.BackgroundColor>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleColorPickerCommand}"/>
                        </Border.GestureRecognizers>
                        <Grid
                            HeightRequest="52"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12">

                            <!-- Live swatch circle -->
                            <Border
                                Grid.Column="0"
                                WidthRequest="28"
                                HeightRequest="28"
                                StrokeShape="RoundRectangle 14"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                BackgroundColor="{Binding SelectedColor, Converter={StaticResource HexToColor}}"/>

                            <Label
                                Grid.Column="1"
                                Text="{Binding SelectedColor}"
                                FontSize="14"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                            <Label
                                Grid.Column="2"
                                Text="▾"
                                FontSize="14"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                        </Grid>
                    </Border>

                    <!-- Inline color swatch grid -->
                    <Border
                        IsVisible="{Binding IsColorPickerVisible}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">

                        <FlexLayout
                            Wrap="Wrap"
                            JustifyContent="Start"
                            BindableLayout.ItemsSource="{Binding ColorPalette}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="{x:Type x:String}">
                                    <Border
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        StrokeShape="RoundRectangle 20"
                                        StrokeThickness="2.5"
                                        Margin="4"
                                        BackgroundColor="{Binding ., Converter={StaticResource HexToColor}}">
                                        <!--
                                            Stroke highlights the currently selected swatch.
                                            We use a DataTrigger comparing the item to SelectedColor.
                                        -->
                                        <Border.Triggers>
                                            <DataTrigger
                                                TargetType="Border"
                                                Binding="{Binding ., Converter={StaticResource StrEqBool}, ConverterParameter={Binding Source={RelativeSource AncestorType={x:Type vm:EditCategoryViewModel}}, Path=SelectedColor}}"
                                                Value="True">
                                                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                            </DataTrigger>
                                            <DataTrigger
                                                TargetType="Border"
                                                Binding="{Binding ., Converter={StaticResource StrEqBool}, ConverterParameter={Binding Source={RelativeSource AncestorType={x:Type vm:EditCategoryViewModel}}, Path=SelectedColor}}"
                                                Value="False">
                                                <Setter Property="Stroke" Value="Transparent"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditCategoryViewModel}}, Path=SelectColorCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                    </Border>

                </VerticalStackLayout>

                <!-- ── GLOBAL ERROR BANNER ─────────────────────────────────── -->
                <Border
                    IsVisible="{Binding Error.Length, Converter={StaticResource IntIsNonZero}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ErrorContainer}, Dark={StaticResource ErrorContainerDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 10"
                    Padding="14,10">
                    <Label
                        Text="{Binding Error}"
                        FontSize="13"
                        TextColor="{AppThemeBinding Light={StaticResource OnErrorContainer}, Dark={StaticResource OnErrorContainerDark}}"/>
                </Border>

                <!-- ── SAVE BUTTON (full width) ───────────────────────────── -->
                <Button
                    Text="Save category"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}"
                    HeightRequest="52"
                    CornerRadius="12"
                    FontSize="16"
                    FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"/>

                <!-- ── DELETE BUTTON — only visible in edit mode for user categories ── -->
                <Button
                    Text="Delete category"
                    Command="{Binding DeleteCommand}"
                    IsVisible="{Binding CanDelete}"
                    HeightRequest="52"
                    CornerRadius="12"
                    FontSize="16"
                    FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ErrorContainer}, Dark={StaticResource ErrorContainerDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                    BorderColor="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                    BorderWidth="1.5"/>

            </VerticalStackLayout>
            <!-- /body -->

        </VerticalStackLayout>
    </ScrollView>
</uranium:UraniumContentPage>
