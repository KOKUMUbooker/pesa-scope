<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage
    x:Class="PesaLens.App.Views.Dashboard.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
    xmlns:vm="clr-namespace:PesaLens.App.ViewModels"
    xmlns:models="clr-namespace:PesaLens.Core.Models;assembly=PesaLens.Core"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
    xmlns:converters="clr-namespace:PesaLens.App.Converters"
    xmlns:HomeControls="clr-namespace:PesaLens.App.Controls.Home"
    x:DataType="vm:DashboardViewModel"
    Shell.NavBarIsVisible="True"
    SafeAreaEdges="All"
    BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <ContentPage.Resources>
        <converters:TransactionTypeToEmojiConverter  x:Key="TypeToEmoji"/>
        <converters:TransactionTypeToSignConverter   x:Key="TypeToSign"/>
        <converters:TransactionTypeToColorConverter  x:Key="TypeToColor"/>
        <converters:IntIsZeroConverter               x:Key="IntIsZero"/>
        <converters:IntIsNonZeroConverter            x:Key="IntIsNonZero"/>
    </ContentPage.Resources>

    <Shell.TitleView BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
        <Grid
         Padding="10,5,10,5"
         ColumnDefinitions="Auto,*,Auto" >

            <HorizontalStackLayout
             Grid.Column="0"
             Spacing="10"
             VerticalOptions="Center">

                <Label
                 Text="Home"
                 FontSize="22"
                 FontAttributes="Bold"
                 TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                 VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Sync + last-synced label -->
            <VerticalStackLayout
             Grid.Column="2"
             HorizontalOptions="End"
             Spacing="2">

                <ImageButton
                 Command="{Binding RefreshCommand}"
                 BackgroundColor="Transparent"
                 HeightRequest="36"
                 WidthRequest="36"
                 HorizontalOptions="End">
                    <ImageButton.Source>
                        <FontImageSource
                         FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Sync}"
                         Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                         Size="22" />
                    </ImageButton.Source>
                </ImageButton>

                <Label
                 Text="{Binding LastSynced}"
                 FontSize="10"
                 TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                 HorizontalOptions="End"/>
            </VerticalStackLayout>  
        </Grid>
    </Shell.TitleView>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Root – RefreshView wraps everything for pull-to-refresh
    ════════════════════════════════════════════════════════════════════════ -->
    <RefreshView
        Command="{Binding RefreshCommand}"
        IsRefreshing="{Binding IsRefreshing}"
        RefreshColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">

        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Hairline separator -->
                <BoxView
                    HeightRequest="1"
                    Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    Opacity="0.5"/>

                <!-- ─────────────────────────────────────────────────────────
                     SCROLLABLE BODY
                ──────────────────────────────────────────────────────────── -->
                <VerticalStackLayout Padding="20,20,20,40" Spacing="20">

                    <!-- Loading spinner (shown while IsBusy on first load) -->
                    <ActivityIndicator
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        HorizontalOptions="Center"
                        HeightRequest="48"/>

                    <!-- ── NET BALANCE HERO CARD ─────────────────────────── -->
                    <HomeControls:BalanceCardView
                        NetBalance="{Binding FormattedNetBalance}"
                        PeriodLabel="{Binding PeriodLabel}"
                        MoneyIn="{Binding FormattedMoneyIn}"
                        MoneyOut="{Binding FormattedMoneyOut}" />

                    <!-- ── DAILY SPENDING CHART ──────────────────────────── -->
                    <!--
                        Transparent background is set at THREE levels:
                          1. The Border wrapper:   BackgroundColor="Transparent"
                          2. CartesianChart:        Background="Transparent"
                          3. ViewModel:             chart DrawMarginFrame = null,
                                                    Legend/Tooltip paints = null
                                                    (set in LoadChartAsync)
                    -->
                    <Border
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="16,16,16,8">

                        <VerticalStackLayout Spacing="12">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label
                                    Grid.Column="0"
                                    Text="Weekly spending"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                <Label
                                    Grid.Column="1"
                                    Text="{Binding PeriodLabel}"
                                    FontSize="12"
                                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    VerticalOptions="Center"/>
                            </Grid>

                            <!--
                                Key chart transparency attributes:
                                  Background="Transparent"          – clears the default white MAUI view bg
                                  DrawMarginFrame="{x:Null}"        – removes the inner frame LiveCharts draws
                                  LegendPosition="Hidden"           – hides the legend (no background panel)
                                  TooltipPosition="Top"
                                  TooltipBackgroundPaint="{x:Null}" – tooltip bg transparent (set in VM too)
                                  TooltipTextPaint="{x:Null}"       – suppress default tooltip text paint
                            -->
                            <lvc:CartesianChart
                                HeightRequest="180"
                                Background="Transparent"
                                Series="{Binding SpendingSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"
                                DrawMarginFrame="{x:Null}"
                                LegendPosition="Hidden"
                                TooltipPosition="Top"
                                TooltipBackgroundPaint="{x:Null}"
                                TooltipTextPaint="{x:Null}"
                                AnimationsSpeed="00:00:00.600"/>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── TOP CATEGORIES ────────────────────────────────── -->
                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="Top categories"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                        <!-- Horizontally scrollable chips -->
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout
                                Spacing="10"
                                BindableLayout.ItemsSource="{Binding TopCategories}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CategorySpendItem">
                                        <Border
                                            WidthRequest="148"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                            Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="14">
                                            <VerticalStackLayout Spacing="8">
                                                <!-- Icon -->
                                                <Border
                                                    WidthRequest="40"
                                                    HeightRequest="40"
                                                    StrokeShape="RoundRectangle 20"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource PrimaryContainerDark}}">
                                                    <Label
                                                        Text="{Binding Icon}"
                                                        FontSize="18"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center"/>
                                                </Border>
                                                <!-- Name + amount -->
                                                <VerticalStackLayout Spacing="2">
                                                    <Label
                                                        Text="{Binding Name}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                                        LineBreakMode="TailTruncation"/>
                                                    <Label
                                                        Text="{Binding FormattedAmount}"
                                                        FontSize="15"
                                                        FontAttributes="Bold"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                                </VerticalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>

                        <!-- Empty state – shown when TopCategories is empty -->
                        <Label
                            Text="No spending data yet for this period."
                            FontSize="14"
                            HorizontalTextAlignment="Center"
                            HorizontalOptions="Center"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}">
                            <Label.IsVisible>
                                <Binding Path="TopCategories.Count" Converter="{StaticResource IntIsZero}"/>
                            </Label.IsVisible>
                        </Label>

                    </VerticalStackLayout>

                    <!-- ── RECENT TRANSACTIONS ───────────────────────────── -->
                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                Text="Recent transactions"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                            <!--
                                "View all" navigates to the Transactions tab.
                                Binding directly to the ViewModel command avoids
                                AncestorType ancestor-lookup fragility.
                            -->
                            <Label
                                Grid.Column="1"
                                Text="View all"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                VerticalOptions="Center">
                                <!-- Label doesn't have Command; use a TapGestureRecognizer -->
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToTransactionsCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <!-- Transaction list card -->
                        <Border
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="0"
                            IsVisible="{Binding RecentTransactions.Count, Converter={StaticResource IntIsNonZero}}">

                            <VerticalStackLayout
                                BindableLayout.ItemsSource="{Binding RecentTransactions}"
                                Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:Transaction">
                                        <Grid
                                            Padding="16,12"
                                            ColumnDefinitions="44,*,Auto"
                                            ColumnSpacing="12">

                                            <!-- Icon circle -->
                                            <Border
                                                Grid.Column="0"
                                                WidthRequest="44"
                                                HeightRequest="44"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                                                VerticalOptions="Center">
                                                <Label
                                                    Text="{Binding Type, Converter={StaticResource TypeToEmoji}}"
                                                    FontSize="18"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center"/>
                                            </Border>

                                            <!-- Counterparty + date -->
                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Spacing="2"
                                                VerticalOptions="Center">
                                                <Label
                                                    Text="{Binding CounterpartyName}"
                                                    FontSize="15"
                                                    FontAttributes="Bold"
                                                    TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                                                    LineBreakMode="TailTruncation"/>
                                                <Label
                                                    Text="{Binding TransactionDate, StringFormat='{0:ddd d MMM, h:mm tt}'}"
                                                    FontSize="12"
                                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                                            </VerticalStackLayout>

                                            <!-- Amount: sign prefix + value, coloured by type -->
                                            <Label
                                                Grid.Column="2"
                                                FontSize="15"
                                                FontAttributes="Bold"
                                                VerticalOptions="Center"
                                                TextColor="{Binding Type, Converter={StaticResource TypeToColor}}">
                                                <Label.Text>
                                                    <MultiBinding StringFormat="{}{0}Ksh {1:N0}">
                                                        <Binding Path="Type" Converter="{StaticResource TypeToSign}"/>
                                                        <Binding Path="Amount"/>
                                                    </MultiBinding>
                                                </Label.Text>
                                            </Label>

                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Empty state -->
                        <Label
                            Text="No transactions yet. Pull down to sync your M-Pesa messages."
                            FontSize="14"
                            HorizontalTextAlignment="Center"
                            HorizontalOptions="Center"
                            Margin="0,8"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}">
                            <Label.IsVisible>
                                <Binding Path="RecentTransactions.Count" Converter="{StaticResource IntIsZero}"/>
                            </Label.IsVisible>
                        </Label>

                    </VerticalStackLayout>

                </VerticalStackLayout>
                <!-- /body -->

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</uranium:UraniumContentPage>
