<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage
    x:Class="PesaLens.App.Views.Dashboard.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
    xmlns:vm="clr-namespace:PesaLens.App.ViewModels"
    xmlns:models="clr-namespace:PesaLens.Core.Models;assembly=PesaLens.Core"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
    xmlns:HomeControls="clr-namespace:PesaLens.App.Controls.Home"
    x:DataType="vm:DashboardViewModel"
    Shell.NavBarIsVisible="True"
    SafeAreaEdges="All"
    BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <Shell.TitleView BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
        <Grid
         Padding="10,5,10,5"
         ColumnDefinitions="Auto,*,Auto" >

            <HorizontalStackLayout
             Grid.Column="0"
             Spacing="10"
             VerticalOptions="Center">

                <Label
                 Text="Home"
                 FontSize="22"
                 FontAttributes="Bold"
                 TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                 VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Sync + last-synced label -->
            <VerticalStackLayout
             Grid.Column="2"
             HorizontalOptions="End" >

                <ImageButton
                 Command="{Binding RefreshCommand}"
                 BackgroundColor="Transparent"
                 HeightRequest="32"
                 WidthRequest="32"
                 CornerRadius="8"
                 HorizontalOptions="End">
                    <ImageButton.Source>
                        <FontImageSource
                         FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Sync}"
                         Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                         Size="16" />
                    </ImageButton.Source>
                </ImageButton>

                <Label
                 Text="{Binding LastSynced}"
                 FontSize="8"
                 TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                 HorizontalOptions="End"/>
            </VerticalStackLayout>  
        </Grid>
    </Shell.TitleView>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Root – RefreshView wraps everything for pull-to-refresh
    ════════════════════════════════════════════════════════════════════════ -->
    <RefreshView
        Command="{Binding RefreshCommand}"
        IsRefreshing="{Binding IsRefreshing}"
        RefreshColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">

        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Hairline separator -->
                <BoxView
                    HeightRequest="1"
                    Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    Opacity="0.5"/>

                <!-- ─────────────────────────────────────────────────────────
                     SCROLLABLE BODY
                ──────────────────────────────────────────────────────────── -->
                <VerticalStackLayout Padding="20,20,20,40" Spacing="20">

                    <!-- Loading spinner (shown while IsBusy on first load) -->
                    <ActivityIndicator
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        HorizontalOptions="Center"
                        HeightRequest="48"/>

                    <!-- ── NET BALANCE HERO CARD ─────────────────────────── -->
                    <HomeControls:BalanceCardView
                        NetBalance="{Binding FormattedNetBalance}"
                        PeriodLabel="{Binding PeriodLabel}"
                        MoneyIn="{Binding FormattedMoneyIn}"
                        MoneyOut="{Binding FormattedMoneyOut}" />

                    <!-- ── DAILY SPENDING CHART ──────────────────────────── -->
                    <HomeControls:SpendingChartView
                        PeriodLabel="{Binding PeriodLabel}"
                        Series="{Binding SpendingSeries}"
                        XAxes="{Binding XAxes}"
                        YAxes="{Binding YAxes}"/>
                   
                    <!-- ── TOP CATEGORIES ────────────────────────────────── -->
                    <HomeControls:TopCategoriesView
                        Categories="{Binding TopCategories}"/>

                    <!-- ── RECENT TRANSACTIONS ───────────────────────────── -->
                    <HomeControls:RecentTransactionsView
                        Transactions="{Binding RecentTransactions}"
                        ViewAllCommand="{Binding NavigateToTransactionsCommand}"/>
                    
                </VerticalStackLayout>
                <!-- /body -->

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</uranium:UraniumContentPage>
