<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage
    x:Class="PesaLens.App.Views.Onboarding.WelcomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
    xmlns:local="clr-namespace:PesaLens.App.Views.Onboarding"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ── Top bar: Page counter + Skip button ────────────────────── -->
        <Grid Grid.Row="0" Padding="16,52,16,0" HeightRequest="20" ColumnDefinitions="Auto, *, Auto">
            <Label
                x:Name="PageCounterLabel"
                Grid.Column="0"
                Text="1/3"
                VerticalOptions="Center"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                Padding="8,4" />
            <Button
                x:Name="SkipButton"
                Grid.Column="2"
                Text="Skip"
                HorizontalOptions="End"
                VerticalOptions="Center"
                Clicked="OnSkipClicked"
                BackgroundColor="Transparent"
                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                FontSize="14"
                FontAttributes="None"
                Padding="8,4" />
        </Grid>

        <!-- ── CarouselView ────────────────────────────────────────────── -->
        <CarouselView
            x:Name="OnboardingCarousel"
            Grid.Row="1"
            ItemsSource="{Binding Pages}"
            Loop="False"
            HorizontalScrollBarVisibility="Never"
            PositionChanged="OnCarouselPositionChanged">

            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="local:OnboardingPageModel">
                    <Grid RowDefinitions="*, Auto" Padding="32,24,32,0">

                        <!-- Image placeholder -->
                        <Border
                            Grid.Row="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0"
                            Margin="0,0,0,40"
                            HeightRequest="300">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24" />
                            </Border.StrokeShape>
                            <Label
                                Text="{Binding IllustrationPlaceholder}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                FontSize="14" />
                        </Border>

                        <!-- Title + Description -->
                        <VerticalStackLayout Grid.Row="1" Spacing="12">
                            <Label
                                Text="{Binding Title}"
                                FontSize="24"
                                FontAttributes="Bold"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
                            <Label
                                Text="{Binding Description}"
                                FontSize="15"
                                LineHeight="1.5"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        </VerticalStackLayout>

                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>

        </CarouselView>

        <!-- ── Bottom: Next button ────────────────────────────────────── -->
        <Grid
            Grid.Row="2"
            Padding="32,24,32,48">

            <Button
                x:Name="NextButton"
                Text="Next"
                Clicked="OnNextClicked"
                HorizontalOptions="Fill"
                HeightRequest="52"
                CornerRadius="14"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}" />
        </Grid>

    </Grid>

</uranium:UraniumContentPage>
