<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage
    x:Class="PesaLens.App.Views.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
    xmlns:vm="clr-namespace:PesaLens.App.ViewModels"
    xmlns:material="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    x:DataType="vm:SettingsViewModel"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="20,52,20,100" Spacing="24">

            <!-- ── Page Header ───────────────────────────────────────── -->
            <VerticalStackLayout Spacing="4">
                <Label
                    Text="Settings &amp; Security"
                    FontSize="26"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
                <Label
                    Text="Manage your preferences and security options."
                    FontSize="14"
                    LineHeight="1.4"
                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
            </VerticalStackLayout>

            <!-- ── General Settings ──────────────────────────────────── -->
            <VerticalStackLayout Spacing="10">
                <Label
                    Text="GENERAL SETTINGS"
                    FontSize="11"
                    FontAttributes="Bold"
                    CharacterSpacing="1.2"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    StrokeThickness="1"
                    Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <VerticalStackLayout>

                        <!-- Dark Mode -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="14">
                            <Label
                                Grid.Column="0"
                                Text="🌙"
                                FontSize="20"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="1"
                                Text="Dark Mode"
                                FontSize="15"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                            <Switch
                                Grid.Column="2"
                                IsToggled="{Binding IsDarkMode}"
                                Toggled="OnDarkModeToggled"
                                OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                ThumbColor="White"
                                VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Margin="16,0"
                            Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            Opacity="0.5" />

                        <!-- Currency Display -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="14">
                            <Label
                                Grid.Column="0"
                                Text="💱"
                                FontSize="20"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="1"
                                Text="Currency Display"
                                FontSize="15"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                            <HorizontalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center">
                                <Button
                                    x:Name="KshButton"
                                    Text="Ksh"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    HeightRequest="32"
                                    Padding="12,0"
                                    CornerRadius="16"
                                    Clicked="OnKshSelected"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource PrimaryContainerDark}}"
                                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                <Button
                                    x:Name="KesButton"
                                    Text="KES"
                                    FontSize="12"
                                    HeightRequest="32"
                                    Padding="12,0"
                                    CornerRadius="16"
                                    Clicked="OnKesSelected"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                            </HorizontalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Margin="16,0"
                            Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            Opacity="0.5" />

                        <!-- Budget Notifications -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="14">
                            <Label
                                Grid.Column="0"
                                Text="🔔"
                                FontSize="20"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="1"
                                Text="Budget Notifications"
                                FontSize="15"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                            <Switch
                                Grid.Column="2"
                                IsToggled="{Binding BudgetNotificationsEnabled}"
                                Toggled="OnBudgetNotificationsToggled"
                                OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                ThumbColor="White"
                                VerticalOptions="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ── Security ──────────────────────────────────────────── -->
            <VerticalStackLayout Spacing="10">
                <Label
                    Text="SECURITY"
                    FontSize="11"
                    FontAttributes="Bold"
                    CharacterSpacing="1.2"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    StrokeThickness="1"
                    Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <VerticalStackLayout>

                        <!-- Biometric Lock -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="14">
                            <Label
                                Grid.Column="0"
                                Text="🫆"
                                FontSize="20"
                                VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label
                                    Text="Biometric Lock"
                                    FontSize="15"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                                <Label
                                    Text="Use fingerprint to unlock the app"
                                    FontSize="11"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                            </VerticalStackLayout>
                            <Switch
                                Grid.Column="2"
                                IsToggled="{Binding BiometricLockEnabled}"
                                Toggled="OnBiometricToggled"
                                OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                ThumbColor="White"
                                VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Margin="16,0"
                            Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            Opacity="0.5" />

                        <!-- PIN Lock -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="14">
                            <Label
                                Grid.Column="0"
                                Text="🔒"
                                FontSize="20"
                                VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label
                                    Text="PIN Lock"
                                    FontSize="15"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                                <Label
                                    Text="Set a 4-digit PIN to secure the app"
                                    FontSize="11"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                            </VerticalStackLayout>
                            <Switch
                                Grid.Column="2"
                                IsToggled="{Binding PinLockEnabled}"
                                Toggled="OnPinLockToggled"
                                OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                ThumbColor="White"
                                VerticalOptions="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ── Data Management ───────────────────────────────────── -->
            <VerticalStackLayout Spacing="10">
                <Label
                    Text="DATA MANAGEMENT"
                    FontSize="11"
                    FontAttributes="Bold"
                    CharacterSpacing="1.2"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    StrokeThickness="1"
                    Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <VerticalStackLayout>

                        <!-- Sync Now -->
                        <Grid
                            ColumnDefinitions="Auto,*,Auto"
                            Padding="16,14"
                            ColumnSpacing="14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SyncNowCommand}" />
                            </Grid.GestureRecognizers>
                            <Label
                                Grid.Column="0"
                                Text="🔄"
                                FontSize="20"
                                VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label
                                    Text="Sync Now"
                                    FontSize="15"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                                <Label
                                    Text="{Binding LastSyncedText, StringFormat='Last synced: {0}'}"
                                    FontSize="11"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                            </VerticalStackLayout>
                            <Label
                                Grid.Column="2"
                                Text="›"
                                FontSize="20"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        </Grid>

                        <BoxView HeightRequest="1" Margin="16,0"
                            Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            Opacity="0.5" />

                        <!-- Clear All Data -->
                        <Grid
                            ColumnDefinitions="Auto,*,Auto"
                            Padding="16,14"
                            ColumnSpacing="14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ClearAllDataCommand}" />
                            </Grid.GestureRecognizers>
                            <Label
                                Grid.Column="0"
                                Text="🗑️"
                                FontSize="20"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="1"
                                Text="Clear All Data"
                                FontSize="15"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}" />
                            <Label
                                Grid.Column="2"
                                Text="⚠️"
                                FontSize="16"
                                VerticalOptions="Center"
                                Opacity="0.6" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ── About ─────────────────────────────────────────────── -->
            <VerticalStackLayout Spacing="10">
                <Label
                    Text="ABOUT"
                    FontSize="11"
                    FontAttributes="Bold"
                    CharacterSpacing="1.2"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    StrokeThickness="1"
                    Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <VerticalStackLayout>

                        <!-- App Version -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="14">
                            <Label
                                Grid.Column="0"
                                Text="ℹ️"
                                FontSize="20"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="1"
                                Text="App Version"
                                FontSize="15"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                            <Label
                                Grid.Column="2"
                                Text="{Binding AppVersion}"
                                FontSize="12"
                                FontAttributes="Bold"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        </Grid>

                        <BoxView HeightRequest="1" Margin="16,0"
                            Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            Opacity="0.5" />

                        <!-- Send Feedback -->
                        <Grid
                            ColumnDefinitions="Auto,*,Auto"
                            Padding="16,14"
                            ColumnSpacing="14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SendFeedbackCommand}" />
                            </Grid.GestureRecognizers>
                            <Label
                                Grid.Column="0"
                                Text="💬"
                                FontSize="20"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="1"
                                Text="Send Feedback"
                                FontSize="15"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                            <Label
                                Grid.Column="2"
                                Text="↗"
                                FontSize="18"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</uranium:UraniumContentPage>
