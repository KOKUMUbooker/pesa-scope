<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage
    x:Class="PesaLens.App.Views.Transactions.TransactionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uraniumMaterial="clr-namespace:UraniumUI.Material.Controls;assembly=UraniumUI.Material"
    xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:vm="clr-namespace:PesaLens.App.ViewModels"
    xmlns:converters="clr-namespace:PesaLens.App.Converters"
    xmlns:models="clr-namespace:PesaLens.Core.Models;assembly=PesaLens.Core"
    SafeAreaEdges="All"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <Shell.TitleView BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
        <Grid
        Grid.Row="0"
        ColumnDefinitions="*,Auto"
        Padding="5,10,5,10"
        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Label
            Grid.Column="0"
            Text="Transactions"
            FontSize="22"
            FontAttributes="Bold"
            VerticalOptions="Center"
            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
            <ImageButton
            Grid.Column="1"
            Command="{Binding LoadCommand}"
            BackgroundColor="Transparent"
            Padding="8"
            WidthRequest="44" HeightRequest="44">
                <ImageButton.Source>
                    <FontImageSource
                      FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Sync}"
                      Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                      Size="16" />
                </ImageButton.Source>
            </ImageButton>
        </Grid>

    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Top App Bar ───────────────────────────────────────────── -->
    
        <!-- ── Sticky search + filters ───────────────────────────────── -->
        <VerticalStackLayout
            Grid.Row="1"
            Spacing="10"
            Padding="20,10,20,12"
            BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

            <!-- Search bar -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                StrokeThickness="0"
                Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="12,0">
                    <Image Grid.Column="0">
                        <Image.Source>
                            <FontImageSource
                               FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Search}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               Size="20" />
                        </Image.Source>
                    </Image>
                    <Entry
                        Grid.Column="1"
                        x:Name="SearchEntry"
                        Text="{Binding SearchQuery}"
                        Placeholder="Search by name, amount or code"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                        BackgroundColor="Transparent"
                        FontSize="14"
                        ReturnType="Search"
                        HeightRequest="46"
                        TextChanged="OnSearchTextChanged" />
                    <Label
                        Grid.Column="2"
                        Text="✕"
                        FontSize="16"
                        IsVisible="{Binding SearchQuery, Converter={StaticResource StringToBoolConverter}}"
                        VerticalOptions="Center"
                        Margin="8,0,0,0"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClearSearch" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

                <!-- Filter row: Date button + Type chips -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">

                    <!-- Date range button -->
                    <Border
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                        StrokeThickness="0"
                        Padding="12,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDateFilterTapped" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="📅" FontSize="14" VerticalOptions="Center" />
                            <Label
                                Text="{Binding DateRangeLabel}"
                                FontSize="13"
                                FontAttributes="Bold"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Divider -->
                    <BoxView
                        WidthRequest="1"
                        HeightRequest="32"
                        VerticalOptions="Center"
                        Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}" />

                    <!-- Type filter chips -->
                    <CollectionView
                        ItemsSource="{Binding TypeChips}"
                        ItemsLayout="HorizontalList"
                        SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TypeFilterChip">
                                <Border
                                    Margin="0,0,6,0"
                                    Padding="12,8"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="20" />
                                    </Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                            <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TransactionsViewModel}}, Path=SelectTypeCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label
                                        Text="{Binding Label}"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="TextColor"
                                                    Value="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                <Setter Property="TextColor"
                                                    Value="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </HorizontalStackLayout>
            </ScrollView>

            <!-- Category filter chips (3.6) -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8" x:Name="CategoryChipsLayout" HeightRequest="44">
                    <!-- Built in code-behind from Categories list -->
                </HorizontalStackLayout>
            </ScrollView>

        </VerticalStackLayout>

        <!-- ── Transaction list ──────────────────────────────────────── -->
            <Grid Grid.Row="2">

                <!-- Loading -->
                <!--  <ActivityIndicator
                    IsRunning="{Binding IsLoading}"
                    IsVisible="{Binding IsLoading}"
                    Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center" /> -->

                <!-- Empty state -->
                <VerticalStackLayout
                IsVisible="{Binding IsEmpty}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="12"
                Padding="40">
                    <Label Text="🔍" FontSize="48" HorizontalOptions="Center" />
                    <Label
                    Text="No transactions found"
                    FontSize="17"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                    <Label
                    Text="Try adjusting your filters or date range."
                    FontSize="13"
                    HorizontalTextAlignment="Center"
                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                </VerticalStackLayout>

            <RefreshView
                Command="{Binding LoadCommand}"
                IsRefreshing="{Binding IsLoading}"
                RefreshColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                <!-- Grouped transaction list -->
                <CollectionView
                ItemsSource="{Binding GroupedTransactions}"
                IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}"
                Margin="0,4,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TransactionGroup">
                            <VerticalStackLayout Padding="20,0,20,8" Spacing="8">

                                <!-- Date group header -->
                                <Label
                                Text="{Binding DateLabel}"
                                FontSize="11"
                                FontAttributes="Bold"
                                CharacterSpacing="1.0"
                                Margin="0,12,0,4"
                                TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}" />

                                <!-- Transactions in this group -->
                                <VerticalStackLayout  BindableLayout.ItemsSource="{Binding Transactions}" Spacing="8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:Transaction">
                                            <Border
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                            Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                                            StrokeThickness="1"
                                            Padding="14">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="14" />
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TransactionsViewModel}}, Path=OpenTransactionCommand}"
                                                    CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>

                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                                    <!-- Type icon circle -->
                                                    <Border
                                                    Grid.Column="0"
                                                    WidthRequest="46"
                                                    HeightRequest="46"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}">
                                                        <Border.StrokeShape>
                                                            <Ellipse />
                                                        </Border.StrokeShape>
                                                        <Label
                                                        Text="{Binding Type, Converter={StaticResource TransactionTypeToIconConverter}}"
                                                        FontSize="20"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center" />
                                                    </Border>

                                                    <!-- Counterparty + type · category -->
                                                    <VerticalStackLayout
                                                    Grid.Column="1"
                                                    VerticalOptions="Center"
                                                    Spacing="2">
                                                        <Label
                                                        Text="{Binding CounterpartyName}"
                                                        FontSize="15"
                                                        FontAttributes="Bold"
                                                        LineBreakMode="TailTruncation"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                                                        <Label
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}">
                                                            <Label.FormattedText>
                                                                <FormattedString>
                                                                    <Span Text="{Binding Type}" />
                                                                    <Span Text=" · " />
                                                                    <Span Text="{Binding TransactionDate, StringFormat='{0:h:mm tt}'}" />
                                                                </FormattedString>
                                                            </Label.FormattedText>
                                                        </Label>
                                                        <Label
                                                        Text="{Binding MpesaCode}"
                                                        FontSize="11"
                                                        FontFamily="OpenSansRegular"
                                                        TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}" />
                                                    </VerticalStackLayout>

                                                    <!-- Amount -->
                                                    <Label
                                                    Grid.Column="2"
                                                    Text="{Binding Amount, StringFormat='Ksh {0:N0}'}"
                                                    FontSize="14"
                                                    FontAttributes="Bold"
                                                    VerticalOptions="Center"
                                                    TextColor="{Binding Type, Converter={StaticResource TransactionTypeToColorConverter}}" />

                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.Footer>
                        <BoxView HeightRequest="100" Color="Transparent" />
                    </CollectionView.Footer>
                </CollectionView>

            </RefreshView>
            </Grid>

    </Grid>

    <!-- ── Date Range Bottom Sheet ────────────────────────────────────── -->
    <uranium:UraniumContentPage.Attachments>
        <material:BottomSheetView
            x:Name="DateRangeSheet"
            IsPresented="False"
            IsVisible="False"
            CloseOnTapOutside="False"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

            <VerticalStackLayout Padding="24,8,24,48" Spacing="20">
                <AbsoluteLayout >
                    <ImageButton
                        AbsoluteLayout.LayoutBounds="1, 0.5, AutoSize, AutoSize"
                        AbsoluteLayout.LayoutFlags="PositionProportional" 
                        Grid.Column="1"
                        Clicked="OnCloseBottomSheetTapped"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                        Padding="4"
                        CornerRadius="16"
                        WidthRequest="28" HeightRequest="28">
                        <ImageButton.Source>
                            <FontImageSource
                                FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Close}"
                                Color="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"
                                Size="20" />
                        </ImageButton.Source>
                    </ImageButton>
                </AbsoluteLayout>

                <Label
                    Text="Filter by Date"
                    FontSize="18"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />

                <!-- Presets -->
                <Label
                    Text="QUICK PRESETS"
                    FontSize="11"
                    FontAttributes="Bold"
                    CharacterSpacing="1.2"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                    <Button
                        Grid.Row="0" Grid.Column="0"
                        Text="Today"
                        Clicked="OnPresetToday"
                        HeightRequest="42" CornerRadius="21"
                        FontSize="13" FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                    <Button
                        Grid.Row="0" Grid.Column="1"
                        Text="This Week"
                        Clicked="OnPresetWeek"
                        HeightRequest="42" CornerRadius="21"
                        FontSize="13" FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource PrimaryContainerDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                    <Button
                        Grid.Row="1" Grid.Column="0"
                        Text="This Month"
                        Clicked="OnPresetThisMonth"
                        HeightRequest="42" CornerRadius="21"
                        FontSize="13" FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                    <Button
                        Grid.Row="1" Grid.Column="1"
                        Text="Last Month"
                        Clicked="OnPresetLastMonth"
                        HeightRequest="42" CornerRadius="21"
                        FontSize="13" FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                </Grid>

                <!-- Divider -->
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                    <BoxView Grid.Column="0" HeightRequest="1" VerticalOptions="Center"
                        Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}" />
                    <Label Grid.Column="1" Text="or custom" FontSize="12"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                    <BoxView Grid.Column="2" HeightRequest="1" VerticalOptions="Center"
                        Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}" />
                </Grid>

                <!-- Custom date inputs -->
                <Label
                    Text="CUSTOM RANGE"
                    FontSize="11"
                    FontAttributes="Bold"
                    CharacterSpacing="1.2"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">

                    <!-- From date -->
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="From" FontSize="12"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        <Border
                            Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            StrokeThickness="1"
                            Padding="4,0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <DatePicker
                                x:Name="FromDatePicker"
                                Date="{Binding FromDate}"
                                Format="d MMM yyyy"
                                FontSize="13"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                                BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <Label Grid.Column="1" Text="→" FontSize="18"
                        VerticalOptions="End" Margin="0,0,0,8"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />

                    <!-- To date -->
                    <VerticalStackLayout Grid.Column="2" Spacing="6">
                        <Label Text="To" FontSize="12"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        <Border
                            Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                            StrokeThickness="1"
                            Padding="4,0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <DatePicker
                                x:Name="ToDatePicker"
                                Date="{Binding ToDate}"
                                Format="d MMM yyyy"
                                FontSize="13"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                                BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                </Grid>

                <!-- Apply button -->
                <Button
                    Text="Apply Custom Range"
                    Command="{Binding ApplyCustomRangeCommand}"
                    Clicked="OnApplyCustomRange"
                    HorizontalOptions="Fill"
                    HeightRequest="50"
                    CornerRadius="25"
                    FontSize="15"
                    FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}" />

            </VerticalStackLayout>
        </material:BottomSheetView>
    </uranium:UraniumContentPage.Attachments>

    <uranium:UraniumContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InvertedBoolConverter"/>
            <local:StringToBoolConverter x:Key="StringToBoolConverter"
                xmlns:local="clr-namespace:PesaLens.App.Converters" />
            <local:TransactionTypeToIconConverter x:Key="TransactionTypeToIconConverter"
                xmlns:local="clr-namespace:PesaLens.App.Converters" />
            <local:TransactionPageTypeToColorConverter x:Key="TransactionTypeToColorConverter"
                xmlns:local="clr-namespace:PesaLens.App.Converters" />
        </ResourceDictionary>
    </uranium:UraniumContentPage.Resources>

</uranium:UraniumContentPage>
