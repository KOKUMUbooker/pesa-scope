<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage
    x:Class="PesaScope.App.Views.Categories.CategoriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
    xmlns:vm="clr-namespace:PesaScope.App.ViewModels"
    xmlns:models="clr-namespace:PesaScope.Core.Models;assembly=PesaScope.Core"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    xmlns:converters="clr-namespace:PesaScope.App.Converters"
    x:DataType="vm:CategoriesViewModel"
    x:Name="NCategoriesPage"
    SafeAreaEdges="All"
    BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <uranium:UraniumContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        <converters:NullToStringConverter x:Key="NullToStringConverter"/>
        <converters:IntIsZeroConverter x:Key="IntIsZero"/>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
        <converters:BoolToRotationConverter x:Key="BoolToRotationConverter"/>
    </uranium:UraniumContentPage.Resources>

    <!-- ── Title bar ─────────────────────────────────────────────────────── -->
    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto,Auto" Padding="5,10" >
            <Label Grid.Column="0" Text="Categories" FontSize="22" FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
            <ImageButton Grid.Column="1" Command="{Binding OpenAddRuleCommand}"
                         BackgroundColor="Transparent" Padding="8" WidthRequest="44" HeightRequest="44">
                <ImageButton.Source>
                    <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Rule}"
                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Size="20"/>
                </ImageButton.Source>
            </ImageButton>

            <ImageButton Grid.Column="2" Command="{Binding OpenAddCategoryCommand}"
                         BackgroundColor="Transparent" Padding="8" WidthRequest="44" HeightRequest="44">
                <ImageButton.Source>
                    <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Add}"
                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Size="20"/>
                </ImageButton.Source>
            </ImageButton>
        </Grid>
    </Shell.TitleView>

    <uranium:UraniumContentPage.Attachments>

        <!-- ── Add / Edit Category sheet ─────────────────────────────────── -->
        <material:BottomSheetView
            x:Name="CategorySheet"
            IsPresented="{Binding IsSheetOpen}"
            IsVisible="{Binding IsSheetOpen}"
            CloseOnTapOutside="False"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

            <VerticalStackLayout Padding="24,12,24,48" Spacing="16">
                <Label Text="{Binding EditingCategory, Converter={StaticResource NullToStringConverter},
                       ConverterParameter='Edit Category|New Category'}"
                       FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                <VerticalStackLayout Spacing="6">
                    <Label Text="NAME" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,0">
                        <Entry Text="{Binding EditName}" Placeholder="e.g. Subscriptions"
                               FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="COLOR" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="10" x:Name="ColorPickerLayout"/>
                    </ScrollView>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" Text="Cancel" Command="{Binding CloseSheetCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    <Button Grid.Column="1" Text="Save" Command="{Binding SaveCategoryCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"/>
                </Grid>
            </VerticalStackLayout>
        </material:BottomSheetView>

        <!-- ── Add / Edit Rule sheet ──────────────────────────────────────── -->
        <material:BottomSheetView
            x:Name="RuleSheet"
            IsPresented="{Binding IsRuleSheetOpen}"
            IsVisible="{Binding IsRuleSheetOpen}"
            CloseOnTapOutside="False"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

            <VerticalStackLayout Padding="24,12,24,48" Spacing="16">
                <Label Text="Auto-Categorization Rule" FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                <VerticalStackLayout Spacing="6">
                    <Label Text="RULE TYPE" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Picker ItemsSource="{Binding RuleTypes}"
                                SelectedItem="{Binding RuleType}"
                                FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="MATCH VALUE" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,0">
                        <Entry Text="{Binding RuleMatchValue}" Placeholder="e.g. NAIVAS or 888880"
                               FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="ASSIGN TO CATEGORY" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,4"
                            x:Name="CategoryPickerBorder">
                        <Picker x:Name="RuleCategoryPicker"
                                ItemDisplayBinding="{Binding Name}"
                                FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                                SelectedIndexChanged="OnRuleCategorySelected"/>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" Text="Cancel" Command="{Binding CloseSheetCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    <Button Grid.Column="1" Text="Save" Command="{Binding SaveRuleCommand}"
                            HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"/>
                </Grid>
            </VerticalStackLayout>
        </material:BottomSheetView>

        <!-- ── Category filter sheet ─────────────────────────────────────── -->
        <material:BottomSheetView
            x:Name="CategoryFilterSheet"
            IsPresented="{Binding IsCategoryFilterSheetOpen}"
            IsVisible="{Binding IsCategoryFilterSheetOpen}"
            CloseOnTapOutside="False"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

            <VerticalStackLayout Padding="24,12,24,48" Spacing="16">
                <Label Text="Filter &amp; Sort Categories" FontSize="18" FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                <!-- Amount range -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="AMOUNT RANGE (KSH)" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                        StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,0">
                            <Entry Text="{Binding DraftMinAmountText}" Placeholder="Min"
                           Keyboard="Numeric"
                           FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                           PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                        </Border>
                        <Border Grid.Column="1"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                        StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,0">
                            <Entry Text="{Binding DraftMaxAmountText}" Placeholder="Max"
                           Keyboard="Numeric"
                           FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                           PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Category type -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="CATEGORY TYPE" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                    StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Picker ItemsSource="{Binding CategoryTypeFilterOptions}"
                        SelectedItem="{Binding DraftCategoryTypeFilter}"
                        FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Sort by -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="SORT BY" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.2"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                    StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Picker ItemsSource="{Binding CategorySortOptions}"
                        SelectedItem="{Binding DraftCategorySortOption}"
                        FontSize="14" HeightRequest="48" BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="Reset" Command="{Binding ResetCategoryFiltersCommand}"
                    HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    <Button Grid.Column="1" Text="Apply" Command="{Binding ApplyCategoryFiltersCommand}"
                    HeightRequest="50" CornerRadius="25" FontSize="15" FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"/>
                </Grid>
            </VerticalStackLayout>
        </material:BottomSheetView>
    </uranium:UraniumContentPage.Attachments>

    <!-- ── Main content ───────────────────────────────────────────────────── -->
    <RefreshView
        Command="{Binding RefreshCommand}"
        IsRefreshing="{Binding IsRefreshing}"
        RefreshColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">

        <ScrollView>
            <VerticalStackLayout Spacing="24" Padding="20,16,20,40">
                <!-- ── Period selector ───────────────────────────────────────── -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                        StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Picker ItemsSource="{Binding AvailableMonths}"
                            SelectedItem="{Binding SelectedMonth}"
                            FontSize="14" HeightRequest="46" BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                    <Border Grid.Column="1"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                        StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Picker ItemsSource="{Binding AvailableYears}"
                            SelectedItem="{Binding SelectedYear}"
                            FontSize="14" HeightRequest="46" BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                    </Border>
                </Grid>


                <!-- ── Donut chart ───────────────────────────── -->
                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                    StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16">
                    <Grid RowDefinitions="Auto,Auto">

                        <!-- Header -->
                        <!-- Header (tap to expand/collapse) -->
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleChartExpandedCommand}"/>
                            </Grid.GestureRecognizers>

                            <ImageButton Grid.Column="0"
                                 Command="{Binding ToggleChartExpandedCommand}"
                                 BackgroundColor="Transparent" Padding="4"
                                 WidthRequest="32" HeightRequest="32"
                                 VerticalOptions="Center">
                                <ImageButton.Source>
                                    <FontImageSource FontFamily="MaterialSharp"
                                        Glyph="{x:Static m:MaterialSharp.Chevron_right}"
                                        Color="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                        Size="18"/>
                                </ImageButton.Source>
                                <ImageButton.Rotation>
                                    <Binding Path="IsChartExpanded">
                                        <Binding.Converter>
                                            <converters:BoolToRotationConverter/>
                                        </Binding.Converter>
                                    </Binding>
                                </ImageButton.Rotation>
                            </ImageButton>

                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="Spending breakdown"
                                FontSize="16" FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                <Label Text="{Binding PeriodLabel}"
                                    FontSize="12"
                                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Row 1: chart, empty state, and loading indicator all share this cell -->
                        <Grid Grid.Row="1" HeightRequest="220" IsVisible="{Binding IsChartExpanded}">
                            <lvc:PieChart
                                Background="Transparent"
                                Series="{Binding Series}"
                                LegendPosition="Hidden"
                                TooltipPosition="Top"
                                TooltipBackgroundPaint="{x:Null}"
                                TooltipTextPaint="{x:Null}"
                                AnimationsSpeed="00:00:00.500"
                                IsVisible="{Binding IsChartEmpty, Converter={StaticResource InvertedBoolConverter}}" />

                            <VerticalStackLayout
                                Spacing="8"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                IsVisible="{Binding IsChartEmpty}">
                                <Image HorizontalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource FontFamily="MaterialSharp"
                                            Glyph="{x:Static m:MaterialSharp.Pie_chart}"
                                            Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                                            Size="40"/>
                                    </Image.Source>
                                </Image>
                                <Label Text="No spending recorded yet"
                                    FontSize="14" FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                                <Label Text="Transactions you categorize this month will show up here."
                                    FontSize="12" HorizontalTextAlignment="Center"
                                    HorizontalOptions="Center"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                    Opacity="0.7"/>
                            </VerticalStackLayout>

                            <ActivityIndicator
                                IsRunning="{Binding IsChartLoading}"
                                IsVisible="{Binding IsChartLoading}"
                                HorizontalOptions="Center" VerticalOptions="Center"
                                Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                WidthRequest="40" HeightRequest="40"/>
                        </Grid>

                    </Grid>
                </Border>
                <!-- ── Tabs ──────────────────────────────────────────────── -->
                <material:TabView CachingStrategy="CacheOnLayout">

                    <!-- Tab 1 : Categories -->
                    <material:TabItem Title="Categories">
                        <material:TabItem.Content>
                            <VerticalStackLayout Spacing="10" Padding="0,12,0,0">
                                <!-- ── Search + filter ───────────────────────────────────────── -->
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="4,0,4,4">

                                    <!-- Search box -->
                                    <Border Grid.Column="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="12,0">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Image Grid.Column="0" VerticalOptions="Center">
                                                <Image.Source>
                                                    <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Search}"
                                                        Color="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                                        Size="16"/>
                                                </Image.Source>
                                            </Image>
                                            <Entry Grid.Column="1"
                                               Text="{Binding CategorySearchText}"
                                               Placeholder="Search categories..."
                                               FontSize="14" HeightRequest="44" BackgroundColor="Transparent"
                                               ClearButtonVisibility="WhileEditing"
                                               PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Filter button (with active-filter badge) -->
                                    <Grid Grid.Column="1" WidthRequest="44" HeightRequest="44">
                                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                                            StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                            <ImageButton Command="{Binding OpenCategoryFilterSheetCommand}"
                                                BackgroundColor="Transparent" Padding="10">
                                                <ImageButton.Source>
                                                    <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Tune}"
                                                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                                        Size="20"/>
                                                </ImageButton.Source>
                                            </ImageButton>
                                        </Border>
                                        <BoxView WidthRequest="9" HeightRequest="9" CornerRadius="4.5"
                                             Color="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                                             HorizontalOptions="End" VerticalOptions="Start"
                                             Margin="0,4,4,0"
                                             IsVisible="{Binding HasActiveCategoryFilters}"
                                             InputTransparent="True"/>
                                    </Grid>
                                </Grid>

                                <Border
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="0">
                                    <Grid>
                                        <VerticalStackLayout
                                        BindableLayout.ItemsSource="{Binding CategoryRows}"
                                        Spacing="0"
                                        IsVisible="{Binding IsChartLoading, Converter={StaticResource InvertedBoolConverter}}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CategorySpendRow">
                                                    <Border
                                                        Margin="4"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 12"
                                                        Padding="12">   

                                                        <VerticalStackLayout Spacing="8">

                                                            <!-- Top row: color dot + category name + chevron -->
                                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                                                                <BoxView Grid.Column="0"
                                                                 WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                                                 Color="{Binding ChartColor}" VerticalOptions="Center"/>
                                                                <Label Grid.Column="1"
                                                                   Text="{Binding Category.Name}"
                                                                   FontSize="13" FontAttributes="Bold"
                                                                   VerticalOptions="Center"
                                                                   LineBreakMode="TailTruncation"
                                                                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                                                                <HorizontalStackLayout Grid.Column="2" Spacing="10" >
                                                                    <!-- Edit button (non-system categories only) -->
                                                                    <ImageButton
                                                                        BackgroundColor="Transparent"
                                                                        HorizontalOptions="End"
                                                                        WidthRequest="28" HeightRequest="28"
                                                                        CornerRadius="5"
                                                                        IsVisible="{Binding Category.IsSystemCategory, Converter={StaticResource InvertedBoolConverter}}"
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=OpenEditCategoryCommand}"
                                                                        CommandParameter="{Binding .}">
                                                                        <ImageButton.Source>
                                                                            <FontImageSource FontFamily="MaterialSharp"
                                                                                Glyph="{x:Static m:MaterialSharp.Edit}"
                                                                                Color="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                                                                Size="14"/>
                                                                        </ImageButton.Source>
                                                                    </ImageButton>

                                                                    <!-- Delete button (non-system categories only) -->
                                                                    <ImageButton
                                                                        BackgroundColor="Transparent"
                                                                        HorizontalOptions="End"
                                                                        WidthRequest="28" HeightRequest="28"
                                                                        CornerRadius="5"
                                                                        IsVisible="{Binding Category.IsSystemCategory, Converter={StaticResource InvertedBoolConverter}}"
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=DeleteCategoryCommand}"
                                                                        CommandParameter="{Binding .}">
                                                                        <ImageButton.Source>
                                                                            <FontImageSource FontFamily="MaterialSharp"
                                                                                Glyph="{x:Static m:MaterialSharp.Delete}"
                                                                                Color="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                                                                                Size="14"/>
                                                                        </ImageButton.Source>
                                                                    </ImageButton>

                                                                    <ImageButton 
                                                                         BackgroundColor="Transparent"
                                                                         WidthRequest="28" HeightRequest="28"
                                                                         CornerRadius="5"
                                                                         Clicked="OnCategoryItemTapped">
                                                                        <ImageButton.Source>
                                                                            <FontImageSource FontFamily="MaterialSharp"
                                                                                Glyph="{x:Static m:MaterialSharp.Chevron_right}"
                                                                                Color="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                                                                Size="16"/>
                                                                        </ImageButton.Source>
                                                                    </ImageButton>
                                                                </HorizontalStackLayout>
                                                            </Grid>

                                                            <!-- Amount -->
                                                            <Label Text="{Binding FormattedAmount}"
                                                               FontSize="16" FontAttributes="Bold"
                                                               LineBreakMode="TailTruncation"
                                                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                                                            <!-- Percentage bar -->
                                                            <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                                                                <ProgressBar Grid.Row="0"
                                                                     Progress="{Binding ProgressValue}"
                                                                     ProgressColor="{Binding ChartColor}"
                                                                     BackgroundColor="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                                                                     HeightRequest="4"/>
                                                                <Label Grid.Row="1"
                                                                       Text="{Binding FormattedPercentage}"
                                                                       FontSize="11"
                                                                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                                                            </Grid>

                                                          
                                                        </VerticalStackLayout>
                                                    </Border>
                                                </DataTemplate>

                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                        <ActivityIndicator
                                        IsRunning="{Binding IsChartLoading}"
                                        IsVisible="{Binding IsChartLoading}"
                                        HorizontalOptions="Center" VerticalOptions="Center"
                                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                        WidthRequest="40" HeightRequest="40"/>
                                    </Grid>
                                </Border>

                                <Label Text="{Binding CategoriesEmptyMessage}"
                                   IsVisible="{Binding CategoryRows.Count, Converter={StaticResource IntIsZero}}"
                                   FontSize="14" HorizontalTextAlignment="Center" HorizontalOptions="Center"
                                   Margin="0,16"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                            </VerticalStackLayout>
                        </material:TabItem.Content>
                    </material:TabItem>

                    <!-- Tab 2 : Rules -->
                    <material:TabItem Title="Rules">
                        <material:TabItem.Content>
                            <VerticalStackLayout Spacing="10" Padding="0,12,0,0">
                                <!-- ── Search + filter ───────────────────────────────────────── -->
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="4,0,4,4">

                                    <!-- Search box -->
                                    <Border Grid.Column="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="12,0">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Image Grid.Column="0" VerticalOptions="Center">
                                                <Image.Source>
                                                    <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Search}"
                                                        Color="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                                        Size="16"/>
                                                </Image.Source>
                                            </Image>
                                            <Entry Grid.Column="1"
                                                Text="{Binding RuleSearchText}"
                                                Placeholder="Search rules..."
                                                FontSize="14" HeightRequest="44" BackgroundColor="Transparent"
                                                ClearButtonVisibility="WhileEditing"
                                                PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Category filter -->
                                    <Border Grid.Column="1"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="10,0"
                                        WidthRequest="140">
                                        <Picker ItemsSource="{Binding RuleFilterCategories}"
                                            ItemDisplayBinding="{Binding Name}"
                                            SelectedItem="{Binding RuleFilterCategory}"
                                            FontSize="13" HeightRequest="44" BackgroundColor="Transparent"
                                            TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                    </Border>
                                </Grid>

                                <Border
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="0">
                                    <Grid>
                                        <VerticalStackLayout
                                        BindableLayout.ItemsSource="{Binding Rules}"
                                        Spacing="0"
                                        IsVisible="{Binding IsRulesLoading, Converter={StaticResource InvertedBoolConverter}}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:AutoCategorizationRule">
                                                    <Border
                                                        Margin="4"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant}, Dark={StaticResource SurfaceVariantDark}}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 12"
                                                        Padding="12">
                                                            <VerticalStackLayout Spacing="8">

                                                                <!-- Match value + action buttons -->
                                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4">
                                                                    <Label Grid.Column="0"
                                                                       Text="{Binding MatchValue}"
                                                                       FontSize="14" FontAttributes="Bold"
                                                                       VerticalOptions="Center"
                                                                       LineBreakMode="TailTruncation"
                                                                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                                                                    <ImageButton Grid.Column="1"
                                                                         BackgroundColor="Transparent"
                                                                         WidthRequest="28" HeightRequest="28"
                                                                         Command="{Binding BindingContext.OpenEditRuleCommand, Source={x:Reference NCategoriesPage}}"
                                                                         CommandParameter="{Binding .}">
                                                                        <ImageButton.Source>
                                                                            <FontImageSource FontFamily="MaterialSharp"
                                                                            Glyph="{x:Static m:MaterialSharp.Edit}"
                                                                            Color="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"
                                                                            Size="14"/>             
                                                                        </ImageButton.Source>
                                                                    </ImageButton>
                                                                    <ImageButton Grid.Column="2"
                                                                         BackgroundColor="Transparent"
                                                                         WidthRequest="28" HeightRequest="28"
                                                                         Command="{Binding BindingContext.DeleteRuleCommand, Source={x:Reference NCategoriesPage}}"
                                                                         CommandParameter="{Binding .}">
                                                                        <ImageButton.Source>
                                                                            <FontImageSource FontFamily="MaterialSharp"
                                                                            Glyph="{x:Static m:MaterialSharp.Delete}"
                                                                            Color="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                                                                            Size="14"/> 
                                                                        </ImageButton.Source>
                                                                    </ImageButton>
                                                                </Grid>

                                                                <!-- Rule type badge -->
                                                                <Border
                                                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource PrimaryContainerDark}}"
                                                                    StrokeThickness="0"
                                                                    StrokeShape="RoundRectangle 6"
                                                                    Padding="8,4"
                                                                    HorizontalOptions="Start">
                                                                    <Label Text="{Binding RuleType}"
                                                                       FontSize="11" FontAttributes="Bold"
                                                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                                                </Border>

                                                                <!-- Divider -->
                                                                <BoxView HeightRequest="1"
                                                                    Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"/>

                                                                <!-- Linked category -->
                                                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                                                    <BoxView
                                                                        WidthRequest="8" HeightRequest="8" CornerRadius="4"
                                                                        VerticalOptions="Center"
                                                                        Color="{Binding Category.Color, Converter={StaticResource StringToColorConverter}}"/>
                                                                    <Label
                                                                        Text="{Binding Category.Name, FallbackValue='Uncategorized'}"
                                                                        FontSize="12"
                                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                                                                </HorizontalStackLayout>

                                                            </VerticalStackLayout>
                                                        </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                        <ActivityIndicator
                                        IsRunning="{Binding IsRulesLoading}"
                                        IsVisible="{Binding IsRulesLoading}"
                                        HorizontalOptions="Center" VerticalOptions="Center"
                                        Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                        WidthRequest="40" HeightRequest="40"/>
                                    </Grid>
                                </Border>

                                <Label Text="{Binding RulesEmptyMessage}"
                                   IsVisible="{Binding Rules.Count, Converter={StaticResource IntIsZero}}"
                                   FontSize="14" HorizontalTextAlignment="Center" HorizontalOptions="Center"
                                   Margin="0,4"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}"/>
                            </VerticalStackLayout>
                        </material:TabItem.Content>
                    </material:TabItem>

                </material:TabView>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
    
</uranium:UraniumContentPage>