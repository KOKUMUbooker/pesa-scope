<?xml version="1.0" encoding="UTF-8" ?>
<uranium:UraniumContentPage x:Class="PesaScope.App.Views.Security.AppLockPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
             xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <Grid RowDefinitions="*,Auto,*" Padding="32">

        <!-- Top: time + date -->
        <VerticalStackLayout Grid.Row="0" VerticalOptions="End" HorizontalOptions="Center" Spacing="4">
            <Label x:Name="TimeLabel"
                   FontSize="52"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
            <Label x:Name="DateLabel"
                   FontSize="13"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
        </VerticalStackLayout>

        <!-- Middle: logo + name + subtitle -->
        <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="12" Margin="0,40">
            <Image Source="logo_rounded.png"
                   WidthRequest="80"
                   HeightRequest="80"
                   HorizontalOptions="Center" />
            <Label Text="PesaScope"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
            <Label Text="Verify your identity to access your finances"
                   FontSize="13"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
        </VerticalStackLayout>

        <!-- Bottom: unlock button -->
        <VerticalStackLayout Grid.Row="2" VerticalOptions="Start" HorizontalOptions="Fill" Spacing="8">
            <Button Text="Unlock"
                    Clicked="OnUnlockClicked"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}"
                    CornerRadius="14"
                    HeightRequest="52"
                    FontSize="16"
                    FontAttributes="Bold" />
            <Label Text="Use fingerprint, face, or device PIN"
                   FontSize="11"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource OnSurfaceVariantDark}}" />
        </VerticalStackLayout>

    </Grid>
</uranium:UraniumContentPage>